<div class="py-4">
  <!-- Блок большой поисковой строки -->
  <div class="p-5 mb-4 rounded-4 shadow-sm border bg-white text-center">
    <h2 class="fw-bold text-dark mb-2">🔍 Онлайн-расписание врачей Smart Clinic</h2>
    <p class="text-muted mb-4">Найдите нужного специалиста по имени или направлению медицины</p>
    
    <form action="/" method="GET" class="row g-2 justify-content-center max-w-lg mx-auto" style="max-width: 600px;">
      <div class="col-sm-9">
        <input 
          type="text" 
          name="search" 
          class="form-control form-control-lg border-2 shadow-sm" 
          placeholder="Введите имя врача или специальность (например: dentist)..."
          value="{{searchQuery}}"
        >
      </div>
      <div class="col-sm-3">
        <button type="submit" class="btn btn-clinic-primary btn-lg w-100 shadow-sm fw-semibold">Найти</button>
      </div>
    </form>
  </div>

  <!-- Результаты поиска и карточки врачей -->
  <h4 class="fw-bold text-secondary mb-3">👨‍⚕️ Доступные специалисты и рабочие часы:</h4>
  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    {{#each doctors}}
      <div class="col">
        <div class="card h-100 shadow-sm border p-3 hover-shadow-clinic">
          <div class="card-body">
            <div class="d-flex align-items-center gap-3 mb-3">
              <span class="display-5">🩺</span>
              <div>
                <h5 class="fw-bold text-dark mb-0">{{this.user_id.full_name}}</h5>
                <span class="badge bg-info text-white mt-1">{{translateSpecialization this.specialization}}</span>
              </div>
            </div>

            <div class="small text-muted mb-2">🚪 Кабинет: <b class="text-dark">№ {{this.room_number}}</b></div>
            <div class="small text-muted mb-3">🎓 Опыт: <b class="text-dark">{{this.experience}}</b></div>

            <!-- Сетка расписания этого доктора -->
            <h6 class="fw-bold text-secondary small border-top pt-2 mb-2">📅 График работы:</h6>
            <div class="d-flex flex-column gap-1">
              {{#each this.working_hours}}
                <div class="d-flex justify-content-between align-items-center bg-light p-2 rounded border border-dashed text-xs" style="font-size: 0.85rem;">
                  <span class="fw-semibold text-success">● {{this.work_day}}</span>
                  <span class="badge bg-secondary px-2 py-1">⏱ {{this.start_time}} - {{this.end_time}}</span>
                </div>
              {{else}}
                <div class="text-xs text-warning py-1">⚠️ Расписание на текущую неделю формируется</div>
              {{/each}}
            </div>
          </div>
        </div>
      </div>
    {{else}}
      <div class="col-12 text-center py-5 text-muted">
        🔍 По вашему запросу «<b>{{searchQuery}}</b>» специалистов не найдено. Попробуйте изменить параметры поиска.
      </div>
    {{/each}}
  </div>
</div>
