<div class="page-header"><h1>🏥 Smart Clinic</h1><p>Современная медицинская система</p></div>
<div class="card p-4">
<div class="row g-4 mt-2">
  <!-- Левая колонка: Карточка профиля -->
  <div class="col-md-4">
    <div class="card shadow border-0 text-center p-4">
      <div class="card-body">
        <div class="display-3 mb-3">👤</div>
        <h4 class="fw-bold text-dark mb-1">{{user.full_name}}</h4>
        <p class="text-muted small mb-3">{{user.email}}</p>
        
        <!-- ✅ FIX: user.data.role -> user.role; '==' -> '===' (main.ts da faqat === va !== ro'yxatda) -->
        {{#ifCond user.role '===' 'admin'}}
          <span class="badge bg-danger px-3 py-2 fs-6 shadow-sm">Администратор</span>
        {{/ifCond}}
        {{#ifCond user.role '===' 'doctor'}}
          <span class="badge bg-success px-3 py-2 fs-6 shadow-sm">Врач клиники</span>
        {{/ifCond}}
        {{#ifCond user.role '===' 'patient'}}
          <span class="badge bg-primary px-3 py-2 fs-6 shadow-sm">Пациент</span>
        {{/ifCond}}

        <hr class="my-4">

        <!-- Статус Telegram-бота -->
        <div class="p-3 border rounded bg-light text-start shadow-sm">
          <h6 class="fw-bold text-secondary mb-2">🤖 Telegram-уведомления</h6>
          {{#if user.telegram_id}}
            <div class="text-success small d-flex align-items-center gap-2">
              <span>●</span> Бот успешно подключен
            </div>
            <p class="text-muted text-xs mt-1 mb-0" style="font-size: 0.75rem;">ID: {{user.telegram_id}}</p>
          {{else}}
            <div class="text-warning small d-flex align-items-center gap-2 mb-3">
              <span>●</span> Бот не подключен
            </div>
            <script 
              async 
              src="https://telegram.org/js/telegram-widget.js?22"
              data-telegram-login="clinic_jsdelivr_bot" 
              data-size="medium" 
              data-radius="10"
              data-auth-url="/auth/telegram/callback" 
              data-request-access="write">
            </script>
          {{/if}}
        </div>
      </div>
    </div>
  </div>

  <!-- Правая колонка: Быстрые действия и Меню управления -->
  <div class="col-md-8">
    <div class="card shadow border-0 p-4 h-100">
      <h4 class="fw-bold text-primary mb-4">Панель управления</h4>
      
      <div class="row g-3">
        <!-- Блок для Пациента -->
        {{#ifCond user.role '===' 'patient'}}
          <div class="col-md-6">
            <div class="p-3 border rounded bg-light hover-shadow h-100 d-flex flex-column justify-content-between shadow-sm">
              <div>
                <h5 class="fw-bold text-dark">📅 Запись на прием</h5>
                <p class="text-muted small">Выберите врача, дату и отправьте заявку в клинику.</p>
              </div>
              <a href="/appointments/patient-book" class="btn btn-primary w-100 mt-2">Оставить заявку на прием</a>
            </div>
          </div>
          <div class="col-md-6">
            <div class="p-3 border rounded bg-light hover-shadow h-100 d-flex flex-column justify-content-between shadow-sm">
              <div>
                <h5 class="fw-bold text-dark">📜 Мои записи</h5>
                <p class="text-muted small">Просмотр истории визитов и текущего статуса одобрения.</p>
              </div>
              <a href="/appointments/my-history" class="btn btn-outline-primary w-100 mt-2">Открыть историю</a>
            </div>
          </div>
        {{/ifCond}}

        <!-- Блок для Врача -->
        {{#ifCond user.role '===' 'doctor'}}
          <div class="row g-3">
            
            <!-- КАРТОЧКА 1: Журнал приемов -->
            <div class="col-md-6">
              <div class="p-3 border rounded bg-light hover-shadow h-100 d-flex flex-column justify-content-between shadow-sm">
                <div>
                  <h5 class="fw-bold text-success">📝 Список приемов пациентов</h5>
                  <p class="text-muted small">Просматривайте входящие заявки, назначайте свободные часы и утверждайте визиты.</p>
                </div>
                <!-- ОФИЦИАЛЬНАЯ КНОПКА ДЛЯ ДОКТОРА -->
                <a href="/appointments/doctor-list" class="btn btn-success w-100 mt-2 fw-medium">
                  Открыть журнал приемов
                </a>
              </div>
            </div>

            <!-- КАРТОЧКА 2: Расписание -->
            <div class="col-md-6">
              <div class="p-3 border rounded bg-light hover-shadow h-100 d-flex flex-column justify-content-between shadow-sm">
                <div>
                  <h5 class="fw-bold text-dark">⚙️ Рабочие часы</h5>
                  <p class="text-muted small">Редактируйте свои рабочие дни недели и временные интервалы клиники.</p>
                </div>
                <a href="/schedules/manage" class="btn btn-outline-success w-100 mt-2 fw-medium">
                  Настроить расписание
                </a>
              </div>
            </div>

          </div>
        {{/ifCond}}

        <!-- Блок для Администратора -->
        {{#ifCond user.role '===' 'admin'}}
          <div class="col-md-6">
            <div class="p-3 border rounded bg-light hover-shadow h-100 d-flex flex-column justify-content-between shadow-sm">
              <div>
                <h5 class="fw-bold text-dark">👥 Управление пользователями</h5>
                <p class="text-muted small">Просмотр списка зарегистрированных лиц и изменение их ролей.</p>
              </div>
              <a href="/admin/users" class="btn btn-danger w-100 mt-2">Открыть базу пользователей</a>
            </div>
          </div>
          <div class="col-md-6">
            <div class="p-3 border rounded bg-light hover-shadow h-100 d-flex flex-column justify-content-between shadow-sm">
              <div>
                <h5 class="fw-bold text-dark">🏥 Доктора и Отделения</h5>
                <p class="text-muted small">Активация врачей, назначение в кабинеты, выбор специализаций и контроль филиалов.</p>
              </div>
              <div class="d-flex gap-2 mt-2">
                <a href="/admin/doctors/management" class="btn btn-primary w-100 mt-2">Управление персоналом</a>
              </div>
            </div>
          </div>
        {{/ifCond}}
      </div>

      <hr class="my-4 mt-auto">
      <div class="d-flex justify-content-end">
        <a href="/auth/logout" class="btn btn-outline-secondary px-4">Выйти из аккаунта</a>
      </div>
    </div>
  </div>
</div>

</div>
