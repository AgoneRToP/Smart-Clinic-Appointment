<div class="row justify-content-center mt-4">
  <div class="col-md-7">
    <div class="card shadow border-0 p-4">
      <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
          <h3 class="fw-bold text-primary mb-1">🏥 Заявка на прием к врачу</h3>
          <p class="text-muted mb-0">Выберите специалиста, и мы подберем для вас удобное время визита.</p>
        </div>
        <a href="/profile" class="btn btn-outline-secondary px-3 rounded-3">↩ В профиль</a>
      </div>

      <!-- Отправляет данные на POST /appointments/patient-request -->
      <form action="/appointments/patient-request" method="POST">
        
        <!-- Выбор врача из списка -->
        <div class="mb-4">
          <label for="doctor_id" class="form-label fw-bold text-secondary mb-2">Выберите специалиста</label>
          <select name="doctor_id" id="doctor_id" class="form-select form-select-lg shadow-sm" required>
            <option value="" disabled selected>-- Доступные врачи клиники --</option>
            {{#each doctors}}
              <option value="{{this._id}}">👨‍⚕️ {{this.user_id.full_name}} — {{translateSpecialization this.specialization}} (Каб. {{this.room_number}})</option>
            {{/each}}
          </select>
        </div>

        <!-- Желаемый период или комментарий (Добавлено для удобства) -->
        <div class="mb-4">
          <label for="comment" class="form-label fw-bold text-secondary mb-2">Желаемая дата или симптомы (комментарий)</label>
          <textarea 
            name="comment" 
            id="comment" 
            rows="3" 
            class="form-control shadow-sm" 
            placeholder="Например: Хочу записаться на вторую половину среды, беспокоит кашель..."
          ></textarea>
        </div>

        <button type="submit" class="btn btn-primary btn-lg w-100 shadow mt-2 py-3 rounded-3 fw-bold">
          📩 Отправить заявку клинике
        </button>
      </form>
    </div>
  </div>
</div>
