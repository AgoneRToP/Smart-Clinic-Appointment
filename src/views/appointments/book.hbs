<div class="row justify-content-center mt-4">
  <div class="col-md-7">
    <div class="card shadow border-0 p-4">
      <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
          <h3 class="fw-bold text-success mb-1">📅 Оформление визита пациента</h3>
          <p class="text-muted mb-0">Начните вводить имя или почту пациента для быстрого поиска в базе.</p>
        </div>
        <a href="/profile" class="btn btn-outline-secondary px-3 rounded-3">↩ В профиль</a>
      </div>

      <form action="/appointments/book" method="POST">
        
        <!-- 🔍 ИНТЕЛЛЕКТУАЛЬНЫЙ ПОИСК ПАЦИЕНТА (Вместо обычного Select) -->
        <div class="mb-4">
          <label for="patient_search" class="form-label fw-bold text-secondary mb-2">Найти и выбрать пациента</label>
          
          <!-- Текстовое поле, привязанное к списку пациентов -->
          <input 
            list="patients_list" 
            id="patient_search" 
            class="form-control form-control-lg bg-white shadow-sm" 
            placeholder="Введите первые буквы ФИО или Email..."
            required
          >
          
          <!-- Скрытое поле, которое физически отправит ID выбранного пациента на бэкенд в DTO -->
          <input type="hidden" name="patient_id" id="patient_id_hidden">

          <!-- Динамический список вариантов для автоподстановки браузером -->
          <datalist id="patients_list">
            {{#each patients}}
              <option data-id="{{this._id}}" value="{{this.full_name}} ({{this.email}})"></option>
            {{/each}}
          </datalist>
          <div class="form-text text-muted small">Если пациента нет в списке, его необходимо сначала зарегистрировать в системе.</div>
        </div>

        <!-- Выбор даты и времени визита -->
        <div class="mb-4">
          <label for="appointment_date" class="form-label fw-bold text-secondary mb-2">Дата и время приема</label>
          <input 
            type="datetime-local" 
            name="appointment_date" 
            id="appointment_date"
            class="form-control form-control-lg bg-white shadow-sm" 
            required
          >
        </div>

        <!-- Кнопка фиксации -->
        <button type="submit" class="btn btn-success btn-lg w-100 shadow mt-3 py-3 rounded-3 fw-bold">
          🚀 Зафиксировать прием пациента
        </button>
      </form>
    </div>
  </div>
</div>

<!-- Маленький JS-скрипт, который на лету вытаскивает скрытый MongoDB _id из выбранной строки datalist -->
<script>
  document.getElementById('patient_search').addEventListener('input', function(e) {
    const inputValue = e.target.value;
    const options = document.querySelectorAll('#patients_list option');
    const hiddenInput = document.getElementById('patient_id_hidden');
    
    hiddenInput.value = ''; // Сбрасываем значение, если совпадение не найдено
    
    for (let i = 0; i < options.length; i++) {
      if (options[i].value === inputValue) {
        hiddenInput.value = options[i].getAttribute('data-id');
        break;
      }
    }
  });
</script>
