<div class="page-header"><h1>🏥 Smart Clinic</h1><p>Современная медицинская система</p></div>
<div class="card p-4">
<div class="card shadow border-0 p-4 mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h3 class="fw-bold text-success mb-1">📝 Журнал приемов пациентов</h3>
      <p class="text-muted mb-0">Управляйте заявками и контролируйте текущую загруженность.</p>
    </div>
    <a href="/profile" class="btn btn-outline-success">В личный кабинет</a>
  </div>

  <div class="table-responsive">
    <table class="table table-hover align-middle border">
      <thead class="table-success">
        <tr>
          <th>#</th>
          <th>Пациент</th>
          <th>Email</th>
          <th>Дата и время</th>
          <th>Статус</th>
          <th class="text-center">Действия</th>
        </tr>
      </thead>
      <tbody>
        {{#each appointments}}
          <tr>
            <td class="fw-bold">{{@index + 1}}</td>
            <td>{{this.patient_id.full_name}}</td>
            <td>{{this.patient_id.email}}</td>
            <td class="fw-semibold text-secondary">{{this.appointment_date}}</td>
            <td>
              {{#ifCond this.status '===' 'Pending'}}
                <span class="badge bg-warning text-dark px-2 py-1">⏳ Ожидает</span>
              {{/ifCond}}
              {{#ifCond this.status '===' 'Scheduled'}}
                <span class="badge bg-success px-2 py-1">✅ Одобрен</span>
              {{/ifCond}}
              {{#ifCond this.status '===' 'Canceled'}}
                <span class="badge bg-danger px-2 py-1">❌ Отменен</span>
              {{/ifCond}}
            </td>
            <td class="text-center">
              {{#ifCond this.status '===' 'Pending'}}
                <div class="d-flex gap-2 justify-content-center">
                  <!-- Форма одобрения -->
                  <form action="/appointments/{{this._id}}/status?_method=PATCH" method="POST" class="d-inline">
                    <input type="hidden" name="status" value="Scheduled">
                    <button type="submit" class="btn btn-sm btn-success px-3">Одобрить</button>
                  </form>
                  <!-- Форма отмены -->
                  <form action="/appointments/{{this._id}}/status?_method=PATCH" method="POST" class="d-inline">
                    <input type="hidden" name="status" value="Canceled">
                    <button type="submit" class="btn btn-sm btn-outline-danger px-3">Отклонить</button>
                  </form>
                </div>
              {{else}}
                <span class="text-muted small">Решение принято</span>
              {{/ifCond}}
            </td>
          </tr>
        {{else}}
          <tr>
            <td colspan="6" class="text-center py-5 text-muted fs-5">📭 На данный момент заявок от пациентов нет.</td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>

</div>