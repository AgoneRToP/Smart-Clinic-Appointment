<div class="page-header"><h1>🏥 Smart Clinic</h1><p>Современная медицинская система</p></div>
<div class="card p-4">
<div class="row justify-content-center mt-5">
  <div class="col-md-5">
    <div class="card shadow border-0">
      <div class="card-header bg-white text-center pt-4">
        <h4 class="card-title fw-bold text-primary">Авторизация</h4>
        <p class="text-muted small">Введите свои данные для входа в личный кабинет</p>
      </div>
      <div class="card-body px-4 py-4">
        
        {{#if error}}
          <div class="alert alert-danger" role="alert">
            {{error}}
          </div>
        {{/if}}

        <form action="/auth/login" method="POST">
          <div class="mb-3">
            <label for="email" class="form-label text-secondary fw-semibold">Email адрес</label>
            <input 
              type="email" 
              name="email" 
              id="email" 
              class="form-control form-control-lg" 
              placeholder="example@clinic.com" 
              required
            >
          </div>

          <div class="mb-4">
            <label for="password" class="form-label text-secondary fw-semibold">Пароль</label>
            <input 
              type="password" 
              name="password" 
              id="password" 
              class="form-control form-control-lg" 
              placeholder="••••••••" 
              required
            >
          </div>

          <button type="submit" class="btn btn-primary btn-lg w-100 shadow-sm mb-3">Войти</button>
        </form>

        <div class="text-center mt-3">
          <span class="text-muted small">Ещё нет аккаунта?</span>
          <a href="/auth/register" class="small text-decoration-none fw-semibold">Зарегистрироваться</a>
        </div>
      </div>
    </div>
  </div>
</div>

</div>