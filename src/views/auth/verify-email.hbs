<div class="row justify-content-center mt-5">
  <div class="col-md-5">
    <div class="card shadow border-0 p-4 text-center">
      <div class="card-body">
        <div class="display-4 mb-3">✉️</div>
        <h3 class="fw-bold text-dark mb-2">Подтверждение Email</h3>
        <p class="text-muted small mb-4">
          Мы отправили одноразовый код активации (PIN) на ваш электронный адрес <b class="text-primary">{{email}}</b>.
        </p>

        <!-- Форма отправки PIN-кода на бэкенд -->
        <form action="/auth/activate-pin" method="POST">
          <!-- Скрытое поле, чтобы бэкенд знал, чей именно PIN мы проверяем -->
          <input type="hidden" name="email" value="{{email}}">

          <div class="mb-4">
            <label for="pin_code" class="form-label small fw-bold text-secondary text-uppercase tracking-wider">Введите 6-значный код</label>
            <input 
              type="text" 
              name="pin" 
              id="pin_code" 
              class="form-control form-control-lg text-center fw-bold letter-spacing-lg shadow-sm" 
              placeholder="000000" 
              maxlength="6"
              style="font-size: 2rem; letter-spacing: 8px;"
              required
            >
          </div>

          <button type="submit" class="btn btn-clinic-primary btn-lg w-100 shadow-sm fw-bold">
            🚀 Активировать аккаунт
          </button>
        </form>

        <hr class="my-4">
        <p class="text-xs text-muted mb-0">Не получили письмо? Проверьте папку «Спам» или обратитесь в поддержку.</p>
      </div>
    </div>
  </div>
</div>
